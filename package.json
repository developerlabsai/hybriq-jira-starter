{
  "name": "hybriq-jira-starter",
  "version": "1.0.0",
  "description": "AI agents for Jira powered by HybrIQ (Atlassian Forge)",
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@hybriq/sdk": "^0.1.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "keywords": [
    "hybriq",
    "jira",
    "atlassian",
    "forge",
    "ai",
    "triage"
